# NOTE: these must be set both in your local .env.local (for `npm run server` /
# `npm run dev`) AND in your Netlify site's environment variables (Site
# configuration > Environment variables) for the deployed api + scheduled-sync
# functions — Netlify Functions do not read local .env files.

# Required: Meta Graph API access token — a System User token with
# leads_retrieval + pages_manage_ads + pages_read_engagement permissions
# (server-side only, never VITE_ prefixed)
META_ACCESS_TOKEN=

# Required: Facebook Page ID that owns the Instant Form(s)
META_PAGE_ID=

# Required: Convex deployment URL
CONVEX_URL=

# Required to actually send Conversions API (CAPI) events: your Meta Pixel ID
META_PIXEL_ID=

# IMPORTANT: CAPI events are NEVER sent to Meta unless this is explicitly set
# to "false" — until then, every event is only logged and marked "skipped".
# This defaults to dry-run for safety; set META_CAPI_DRY_RUN=false to go live.
META_CAPI_DRY_RUN=true

# Optional: Meta test event code (Events Manager > Test Events tab), useful
# while verifying payloads land correctly before going live.
META_TEST_EVENT_CODE=

# Optional: "final_stage_only" (default) suppresses sending a lower-funnel-stage
# CAPI event once a higher stage has already been sent for the same lead.
# Set to "all" to send every positive stage-change event unconditionally.
CAPI_SEND_MODE=final_stage_only

# Optional: default country code (digits only, no "+") used to normalize bare
# national phone numbers before hashing for CAPI's `ph` field. Only applied
# when a number has no explicit country code or "+" prefix. Default: 91 (India).
DEFAULT_PHONE_COUNTRY_CODE=91

# Optional: port for the standalone dev/production server (`npm run server`).
# Not used by the Netlify deployment. Must match the proxy target in
# vite.config.ts if you change it for local dev.
PORT=3001

# Optional: how often (ms) the standalone server (`npm run server`) auto-syncs
# Meta leads via setInterval. Not used by the Netlify deployment, which syncs
# on a cron schedule instead — see netlify/functions/scheduled-sync.ts.
AUTO_SYNC_INTERVAL=600000